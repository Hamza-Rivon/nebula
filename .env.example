# Provider keys — add only the ones you'll use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# Kimi / Moonshot (https://platform.moonshot.ai). KIMI_API_KEY or MOONSHOT_API_KEY both work.
KIMI_API_KEY=

# Optional: host port mapped to container's 8080
NEBULA_PORT=8080

# Optional: override Anthropic upstream (defaults to https://api.anthropic.com/v1)
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: override Kimi base URL (e.g. for the .cn endpoint)
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: point at a self-hosted Ollama (OpenAI-compatible mode)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
