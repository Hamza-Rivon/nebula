# Provider keys — add only the ones you'll use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# Kimi / Moonshot (https://platform.moonshot.ai). KIMI_API_KEY or MOONSHOT_API_KEY both work.
KIMI_API_KEY=

# Optional: host port mapped to container's 8080
NEBULA_PORT=8080

# Optional: override Anthropic upstream (defaults to https://api.anthropic.com/v1)
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: override Kimi base URL (e.g. for the .cn endpoint)
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: point at a self-hosted Ollama (OpenAI-compatible mode)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Optional: seed the database from JSONL transcripts at startup.
# Uncomment NEBULA_SEED_DIR to enable. The container path /seed is mapped
# from NEBULA_SEED_HOST_DIR (default: ./proxy/data_seed). All *.jsonl files
# under that path (recursively) are imported. Each (path, sha256) imports
# exactly once — restart-safe; edited files re-import.
# NEBULA_SEED_DIR=/seed
# NEBULA_SEED_HOST_DIR=./proxy/data_seed
