# Provider keys — add only the ones you'll use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# Kimi / Moonshot (https://platform.moonshot.ai). KIMI_API_KEY or MOONSHOT_API_KEY both work.
KIMI_API_KEY=

# Generic OpenAI-compatible upstream — any company-internal, self-hosted, or
# third-party service that speaks the OpenAI chat-completions API. Routed via
# the model prefix `openai-compatible/<model-id>` (e.g.
# `openai-compatible/gpt-oss-20b`). Setting BASE_URL is enough; API_KEY is
# optional (some local services don't need one).
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Multi-provider config file. When set, fully replaces the env-driven defaults
# above. Lets you declare any number of providers — multiple OpenAI-compatible
# upstreams, multiple Anthropic-compatible endpoints, etc. — each with its own
# id, baseUrl, and credentials. Schema:
#   {
#     "providers": [
#       { "id": "openai",    "kind": "openai",    "baseUrl": "https://api.openai.com/v1",   "apiKeyEnv": "OPENAI_API_KEY" },
#       { "id": "internal",  "kind": "openai",    "baseUrl": "https://llm.internal/v1",     "apiKey": "..." },
#       { "id": "claude-eu", "kind": "anthropic", "baseUrl": "https://eu.anthropic.com/v1", "apiKeyEnv": "ANTHROPIC_EU_KEY", "catalogKey": "anthropic" }
#     ]
#   }
# `kind` is one of: openai, anthropic, google. `catalogKey` overrides the
# models.dev provider key (defaults to `id`). `apiKeyEnv` reads the value
# from a different env var; `apiKey` inlines the literal.
# NEBULA_PROVIDERS_FILE=./providers.json

# Optional: override the disk path for the cached models.dev catalog snapshot.
# Defaults to ./data/cache/models.dev.json.
# NEBULA_CATALOG_CACHE_PATH=./data/cache/models.dev.json

# Optional: host port mapped to container's 8080
NEBULA_PORT=8080

# Optional: override Anthropic upstream (defaults to https://api.anthropic.com/v1)
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: override Kimi base URL (e.g. for the .cn endpoint)
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: point at a self-hosted Ollama (OpenAI-compatible mode)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Optional: seed the database from JSONL transcripts at startup. Set this to
# any host folder containing *.jsonl files (recursively). Each (path, sha256)
# imports once — restart-safe; edited files re-import. Sessions are bucketed
# across 4 synthetic engineers (hash of project dir → stable assignment) so
# the manager dashboard has a populated leaderboard. Leave commented to skip.
# NEBULA_SEED_HOST_DIR=./proxy/data_seed

# Optional: cap the number of sessions imported during a seed pass. Files past
# the cap are reported as `capped` in the boot log and skipped (no parsing, no
# DB writes). The cap is total-DB-aware: if you already have N sessions and
# the cap is N, this run does nothing. Unset = no cap, import everything.
# Useful when feeding a large transcript dump and the analyze job queue would
# otherwise take hours, or when Docker Desktop's 2 GB memory ceiling is
# squeezing you. Each capped session also means one fewer analyze job, since
# the auto-enqueue runs after seeding.
# NEBULA_MAX_SESSIONS=200

# Optional: skip the auto-enqueue of an "all" analyze job after seeding.
# Default is on (1). Set to 0 if you want to seed the events but kick off the
# ML pipeline manually via POST /api/analyze.
# NEBULA_AUTO_ANALYZE_ON_SEED=1

# ---- Insights analyze pipeline ----
# These power the LLM-driven session analyzer the manager dashboard reads.
# All four are optional: if any of {API_BASE_URL, API_KEY, MODEL} is missing,
# the analyzer falls back to deterministic facets. If EMBEDDING_MODEL is
# missing, embeddings are stubbed (clusters are still produced).
#
# The analyzer is triggered manually:
#   POST /api/analyze       body {"all": true}            # only un-processed sessions
#   POST /api/analyze       body {"all": true, "force": true}  # re-run everything
#   POST /api/analyze       body {"sessionId": "<id>"}    # single session
#
# NEBULA_ANALYZE_API_BASE_URL=https://api.example.com/v1
# NEBULA_ANALYZE_API_KEY=sk-...
# NEBULA_ANALYZE_MODEL=claude-opus-4-7
# NEBULA_ANALYZE_EMBEDDING_MODEL=text-embedding-3-large
